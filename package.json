{
  "name": "@qualithm/mqtt-wire",
  "version": "0.1.0",
  "description": "Server-side MQTT protocol codec and connection state machine for JavaScript and TypeScript runtimes.",
  "private": false,
  "type": "module",
  "keywords": [
    "mqtt",
    "mqtt5",
    "mqtt311",
    "protocol",
    "codec",
    "parser",
    "encoder",
    "state-machine",
    "typescript"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": "Qualithm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qualithm/mqtt-wire-js.git"
  },
  "homepage": "https://github.com/qualithm/mqtt-wire-js#readme",
  "bugs": {
    "url": "https://github.com/qualithm/mqtt-wire-js/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "deno": "./dist/index.js",
      "node": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "bun": "./dist/testing/index.js",
      "deno": "./dist/testing/index.js",
      "node": "./dist/testing/index.js",
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "analyze:bundle": "bun run scripts/analyze-bundle.ts",
    "bench": "bun run bench/index.ts",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "dev": "bun --watch run src/index.ts",
    "docs": "typedoc",
    "format:fix": "prettier --write .",
    "format": "prettier --check .",
    "lint:fix": "eslint --fix .",
    "lint": "eslint .",
    "prepublishOnly": "bun run clean && bun run build",
    "start": "bun run src/index.ts",
    "test:conformance": "vitest run src/__tests__/conformance --config vitest.conformance.config.ts",
    "test:coverage:unit": "vitest run --coverage src/__tests__/unit",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/__tests__/unit",
    "test:watch": "vitest",
    "test": "vitest run src/__tests__/unit",
    "typecheck": "tsc -p tsconfig.node.json --noEmit",
    "validate:runtime": "bun run scripts/validate-runtime.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.10",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "10.0.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "fast-check": "^4.5.3",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "mqtt": "^5.15.0",
    "prettier": "3.8.1",
    "typedoc": "0.28.17",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "minimatch": "10.2.3"
  }
}
